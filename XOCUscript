local antiKickPCLDActive = false
local currentGold = nil
local activePCLDLoop = false
local fixedPCLD = nil

-- Internal function to find PCLD automatically
local function autoScanPCLD()
    local nearest = nil
    local shortestDist = math.huge
    local char = Player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    
    if not hrp then return nil end

    for _, v in pairs(workspace:GetChildren()) do
        if v.Name:find("PlayerCharacterLocationDetector") and v:IsA("BasePart") then
            local dist = (v.Position - hrp.Position).Magnitude
            if dist < shortestDist then
                shortestDist = dist
                nearest = v
            end
        end
    end
    fixedPCLD = nearest
    return nearest
end
DefenseExtra:CreateToggle({
    Name = "Auto PCLD Anti Kick",
    Flag = "AutoPCLDAntiKick",
    Default = false,
    Callback = function(Value)
        SetToggleState("AutoPCLDAntiKick", Value)
        antiKickPCLDActive = Value

        -- Shutdown logic: Stops the loop and deletes the item
        if not Value then
            activePCLDLoop = false
            if currentGold then
                pcall(function() 
                    ReplicatedStorage.MenuToys.DestroyToy:FireServer(currentGold) 
                end)
                currentGold = nil
            end
            return
        end

        -- Startup logic
        local char = Player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        
        if hrp then
            -- 1. Locate the PCLD
            fixedPCLD = autoScanPCLD()
            
            if not fixedPCLD then
                Library:Notify({Title = "Anti-Kick", Content = "Error: No PCLD found in workspace!", Duration = 4})
                SetToggleState("AutoPCLDAntiKick", false)
                return
            end

            task.spawn(function()
                -- 2. Spawn the Mayonnaise at the PCLD position
                local spawnPos = fixedPCLD.CFrame * CFrame.new(0, 2, 0)
                local MenuToys = ReplicatedStorage:WaitForChild("MenuToys")
                local SpawnRemote = MenuToys:WaitForChild("SpawnToyRemoteFunction")
                
                SpawnRemote:InvokeServer("SprayCanWD", spawnPos, Vector3.zero)
                
                -- 3. Wait for the item to appear in the player's toy folder
                local folderName = Player.Name .. "SpawnedInToys"
                local toysFolder = workspace:WaitForChild(folderName, 5)
                currentGold = toysFolder and toysFolder:WaitForChild("SprayCanWD", 5)
                
                if currentGold then
                    local holdPart = currentGold:WaitForChild("HoldPart", 5)
                    
                    -- Visual Setup (Makes it Neon Purple and see-through)
                    for _, p in pairs(currentGold:GetDescendants()) do
                        if p:IsA("BasePart") then
                            p.Transparency = 0.5
                            p.Color = Color3.fromRGB(170, 0, 255)
                            p.Material = Enum.Material.Neon
                            p.CanCollide = false
                        end
                    end

                    -- 4. THE GRAB & DROP SEQUENCE
                    -- This tricks the game into thinking you are interacting with it inside the PCLD
                    pcall(function()
                        -- Step A: Grab the item
                        holdPart.HoldItemRemoteFunction:InvokeServer(currentGold, char)
                        task.wait(0.3) -- Essential delay for server sync
                        
                        -- Step B: Drop the item directly into the center of the PCLD
                        holdPart.DropItemRemoteFunction:InvokeServer(
                            currentGold, 
                            fixedPCLD.CFrame, 
                            Vector3.zero
                        )
                    end)

                    -- 5. THE PERSISTENT TELEPORT LOOP
                    -- Keeps the item locked inside the PCLD so the anti-kick stays active
                    activePCLDLoop = true
                    Library:Notify({Title = "Anti-Kick", Content = "Active: Mayonnaise locked in PCLD", Duration = 3})
                    
                    while activePCLDLoop and antiKickPCLDActive and currentGold and fixedPCLD do
